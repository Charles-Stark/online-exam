<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.backend.mapper.SQ1mapper">
    <!--selectQuestionByCourseName-->
    <select id="selectQuestionByCourseName" resultType="com.example.backend.domain.SubjectiveQuestion">
        select * from subjective_question where questionname = #{courseName}
    </select>
    <!--selectQuestionbyQuestionid(Long questionid);-->
    <select id="selectQuestionbyQuestionid" resultType="com.example.backend.domain.SubjectiveQuestion">
        select * from subjective_question where questionid = #{questionid}
    </select>
</mapper>