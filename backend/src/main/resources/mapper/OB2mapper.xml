<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mt.mapper.OB2mapper">
    <!--selectQuestionByCourseName-->
    <select id="selectQuestionByCourseName" resultType="com.mt.domain.Objective_question2">
        select * from objective_question2 where questionname = #{courseName}
    </select>
    <!--selectQuestionbyQuestionid(Long questionid);-->
    <select id="selectQuestionbyQuestionid" resultType="com.mt.domain.Objective_question2">
        select * from objective_question2 where questionid = #{questionid}
    </select>
</mapper>